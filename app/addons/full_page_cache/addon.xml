<?xml version="1.0"?>
<addon scheme="3.0">
    <id>full_page_cache</id>
    <version>0.0.10</version>
    <priority>20000</priority>
    <status>disabled</status>
    <default_language>en</default_language>

    <compatibility>
        <core_version>
            <min>4.3.6</min>
        </core_version>
        <php_extensions>
            <curl>
                <supported>Y</supported>
            </curl>
        </php_extensions>
    </compatibility>

    <settings edition_type="ROOT">
        <sections>
            <section id="general">
                <items>
                    <item id="text_general">
                        <type>template</type>
                        <default_value>general.tpl</default_value>
                    </item>
                    <item id="varnish">
                        <type>header</type>
                    </item>
                    <item id="varnish_host">
                        <type>input</type>
                        <default_value>127.0.0.1:80</default_value>
                    </item>
                </items>
            </section>
        </sections>
    </settings>

    <functions>
        <item for="install">fn_full_page_cache_install</item>
        <item for="uninstall">fn_full_page_cache_uninstall</item>
    </functions>

    <files>
        <file>esi.php</file>
        <file>var/conf/varnish</file>
    </files>
</addon>
